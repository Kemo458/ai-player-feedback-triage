# ---- Database ----
POSTGRES_USER=pf
POSTGRES_PASSWORD=change-me-strong-db-pass
POSTGRES_DB=playerfeedback

# ---- Auth (manager dashboard) ----
PF_MANAGER_USERNAME=manager
PF_MANAGER_PASSWORD=change-me-strong-pass
# 32+ byte random string. Generate: openssl rand -base64 48
PF_JWT_SIGNING_KEY=change-me-please-openssl-rand-base64-48

# ---- Internal service auth (API <-> scraper) ----
INTERNAL_SERVICE_KEY=change-me-internal-key

# ---- LLM (Ollama) ----
LLM_PROVIDER=Ollama
# CPU-friendly model used by the deployed interview environment.
LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT_SECONDS=90
ANALYSIS_CONCURRENCY=1
OLLAMA_MEM_LIMIT=8g
OLLAMA_CPUS=4.0

# ---- Google Play ----
GOOGLEPLAY_MAX_REVIEWS=500
GOOGLEPLAY_PAGE_DELAY_MS=500
GOOGLEPLAY_PAGE_TIMEOUT=30

# ---- Frontend / networking ----
FRONTEND_ORIGIN=http://localhost:8090
PUBLISH_PORT=8090
ASPNETCORE_ENVIRONMENT=Production

# Seed a demo game on first boot (set false for a clean DB)
DEMO_SEED=true
