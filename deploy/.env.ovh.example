# Production environment for the OVH deployment. Copy to `.env` on the server and fill in secrets.
# Generate strong values: openssl rand -base64 48

POSTGRES_USER=pf
POSTGRES_PASSWORD=__STRONG_DB_PASSWORD__
POSTGRES_DB=playerfeedback

PF_MANAGER_USERNAME=manager
PF_MANAGER_PASSWORD=__STRONG_MANAGER_PASSWORD__
PF_JWT_SIGNING_KEY=__OPENSSL_RAND_BASE64_48__

INTERNAL_SERVICE_KEY=__OPENSSL_RAND_BASE64_32__

# Real Ollama model. Constrained for the shared CPU-only host.
LLM_PROVIDER=Ollama
LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT_SECONDS=120
# Throughput: run N analyses at once. Keep ANALYSIS_CONCURRENCY == OLLAMA_NUM_PARALLEL.
ANALYSIS_CONCURRENCY=3
OLLAMA_NUM_PARALLEL=3
OLLAMA_MEM_LIMIT=12g
OLLAMA_CPUS=8.0

GOOGLEPLAY_MAX_REVIEWS=500

# Public origin (through the Cloudflare tunnel).
FRONTEND_ORIGIN=https://feedback.example.com
PUBLISH_PORT=8091
ASPNETCORE_ENVIRONMENT=Production
DEMO_SEED=true
